{
  "meta": {
    "name": "09-full-gamepad-layout: Physical Hardware Mapping",
    "version": "1.0",
    "author": "OmniPad",
    "description": "A complete 1:1 demonstration of the Gamepad API integration. This profile maps every standard controller button and axis to a corresponding virtual widget, creating a perfect bridge between physical console hardware and web-based game engines."
  },
  "items": [
    {
      "id": "$left-pad",
      "type": "root-layer",
      "config": {
        "layout": {
          "left": 0,
          "top": 0,
          "width": "100%",
          "height": "100%"
        },
        "baseType": "root-layer"
      }
    },
    {
      "id": "$ruffle-player",
      "type": "target-zone",
      "config": {
        "cursorEnabled": true,
        "baseType": "target-zone",
        "layout": {
          "stickySelector": ".iframe-wrapper"
        }
      }
    },
    {
      "id": "node_1",
      "type": "d-pad",
      "parentId": "$left-pad",
      "config": {
        "showStick": false,
        "threshold": 0.3,
        "mapping": {
          "up": "ArrowUp",
          "down": "ArrowDown",
          "left": "ArrowLeft",
          "right": "ArrowRight"
        },
        "targetStageId": "$ruffle-player",
        "layout": {
          "left": "60%",
          "top": "70%",
          "height": "25%",
          "isSquare": true,
          "anchor": "center"
        },
        "baseType": "d-pad"
      }
    },
    {
      "id": "node_2",
      "type": "joystick",
      "parentId": "$left-pad",
      "config": {
        "label": "L3",
        "threshold": 0.2,
        "cursorMode": false,
        "cursorSensitivity": 1,
        "targetStageId": "$ruffle-player",
        "mapping": {
          "up": "KeyW",
          "down": "KeyS",
          "left": "KeyA",
          "right": "KeyD"
        },
        "layout": {
          "left": "30%",
          "top": "30%",
          "height": "25%",
          "isSquare": true,
          "anchor": "center"
        },
        "baseType": "joystick"
      }
    },
    {
      "id": "node_3",
      "type": "button",
      "parentId": "$left-pad",
      "config": {
        "label": "P",
        "targetStageId": "$ruffle-player",
        "mapping": "KeyP",
        "layout": {
          "left": "80%",
          "top": "30%",
          "height": "8%",
          "isSquare": true,
          "anchor": "center"
        },
        "baseType": "button",
        "cssClass": "round-button"
      }
    },
    {
      "id": "node_4",
      "type": "button",
      "parentId": "$left-pad",
      "config": {
        "label": "LB",
        "targetStageId": "$ruffle-player",
        "mapping": "MouseRight",
        "layout": {
          "left": "20%",
          "top": "60%",
          "width": "15%",
          "height": "15%",
          "isSquare": true,
          "anchor": "center"
        },
        "baseType": "button"
      }
    },
    {
      "id": "node_5",
      "type": "button",
      "parentId": "$left-pad",
      "config": {
        "label": "LT",
        "targetStageId": "$ruffle-player",
        "mapping": "MouseRight",
        "layout": {
          "left": "20%",
          "top": "85%",
          "width": "15%",
          "height": "15%",
          "isSquare": true,
          "anchor": "center"
        },
        "baseType": "button"
      }
    },
    {
      "id": "$right-pad",
      "type": "root-layer",
      "config": {
        "layout": {
          "left": 0,
          "top": 0,
          "width": "100%",
          "height": "100%"
        },
        "baseType": "root-layer"
      }
    },
    {
